rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Check admin status via the admins collection (not users.role)
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ADMINS — any signed-in user reads their own doc to check their status on login
    // Only existing admins can grant or revoke admin access (first admin added via Firebase Console)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // USERS — own read/write; admin can read all
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if false;
    }

    // ORDERS — customers read own; admin reads and updates all
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId || isAdmin());
      allow update: if isAdmin()
        || (request.auth != null
            && request.auth.uid == resource.data.userId
            && request.resource.data.status == 'cancelled'
            && resource.data.status in ['pending', 'paid']
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'updatedAt', 'statusHistory']));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // PRODUCTS — public read; admin full write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SITE SETTINGS — public read; admin write
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COUPONS — public read; admin write
    match /coupons/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // REVIEWS — public read; authenticated users create their own; admin manages
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // VIDEOS — public read; admin write
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
